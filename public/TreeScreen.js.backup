// TreeScreen.js - ENABLED - Single map from cryptoTree.json only
console.log('TreeScreen.js: Starting to load...');

if (typeof window !== 'undefined' && window.React) {
  console.log('TreeScreen.js: React is available, loading TreeScreen component');
  const { useState, useEffect, useMemo, useRef, useCallback, memo } = React;

  // FIX 1: Ensure tree data exists before component loads - Use CryptoTree.json only
  if (!window.cryptoHustleTree) {
    // Load from CryptoTree.json as centralized source
    fetch('/data/cryptoTree.json')
      .then(res => res.json())
      .then(data => {
        if (data && data.fields) {
          window.cryptoHustleTree = data;
          console.log('TreeScreen: Loaded tree from CryptoTree.json:', data.fields.length, 'fields');
        }
      })
      .catch(() => {
        window.cryptoHustleTree = { fields: [] };
        console.log('TreeScreen: Using empty tree fallback');
      });
  }

  // Notes functionality integrated
  const useNotes = () => {
    const [notes, setNotes] = useState(() => {
      try {
        const stored = localStorage.getItem('cryptoExplorer.v2.notes');
        return stored ? JSON.parse(stored) : [];
      } catch {
        return [];
      }
    });

    const saveNotes = useCallback((newNotes) => {
      try {
        localStorage.setItem('cryptoExplorer.v2.notes', JSON.stringify(newNotes));
        setNotes(newNotes);
      } catch {}
    }, []);

    const addNote = useCallback((sectionId, text) => {
      if (!text || !sectionId) return;
      const note = {
        id: Date.now().toString(),
        sectionId,
        text,
        createdAt: new Date().toISOString()
      };
      const newNotes = [...notes, note];
      saveNotes(newNotes);
    }, [notes, saveNotes]);

    const deleteNote = useCallback((noteId) => {
      const newNotes = notes.filter(n => n.id !== noteId);
      saveNotes(newNotes);
    }, [notes, saveNotes]);

    return { notes, addNote, deleteNote };
  };

  // Persistent expansion state hook - FIXED: No auto-expansion
  const useExpansionState = () => {
    const [expandedIds, setExpandedIds] = useState(() => {
      try {
        const stored = localStorage.getItem('cryptoExplorer.treeExpansion');
        // Clear any stored expansion to prevent auto-expansion issues
        localStorage.removeItem('cryptoExplorer.treeExpansion');
        return new Set(); // Start with no expanded nodes
      } catch {
        return new Set();
      }
    });

    const saveExpansion = useCallback((newExpanded) => {
      try {
        localStorage.setItem('cryptoExplorer.treeExpansion', JSON.stringify([...newExpanded]));
        setExpandedIds(newExpanded);
      } catch {}
    }, []);

    return [expandedIds, saveExpansion];
  };

  // Error Boundary Component
  class TreeErrorBoundary extends React.Component {
    constructor(props) {
      super(props);
      this.state = { hasError: false, error: null };
    }

    static getDerivedStateFromError(error) {
      return { hasError: true };
    }

    componentDidCatch(error, errorInfo) {
      console.error('TreeScreen error:', error, errorInfo);
      this.setState({ error });
    }

    render() {
      if (this.state.hasError) {
        return React.createElement('div', {
          className: 'screen',
          style: { padding: '2rem', textAlign: 'center' }
        }, [
          React.createElement('h2', {
            key: 'title',
            style: { color: '#ef4444', marginBottom: '1rem' }
          }, 'Tree View Error'),
          React.createElement('p', {
            key: 'desc',
            style: { color: '#94a3b8', marginBottom: '1rem' }
          }, 'Something went wrong with the tree visualization.'),
          React.createElement('button', {
            key: 'btn',
            className: 'primary-button',
            onClick: () => window.location.reload()
          }, 'Reload Page')
        ]);
      }
      return this.props.children;
    }
  }

  // Generic children accessor
  const getChildren = (node) => [
    ...(node.categories || []),
    ...(node.subcategories || []),
    ...(node.nodes || []),
    ...(node.subnodes || []),
    ...(node.leafnodes || [])
  ];

  function TreeScreen({ tree, onOpenArticle, bookmarksApi }) {
    console.log('TreeScreen: Component called with props:', { 
      tree: tree ? 'loaded' : 'null', 
      fieldsCount: tree?.fields?.length || 0,
      bookmarksCount: bookmarksApi?.bookmarks?.length || 0
    });
    
    // Enhanced error boundary for tree data
    if (!tree) {
      console.error('TreeScreen: Tree prop is null/undefined');
      return React.createElement('div', {
        className: 'screen',
        style: { padding: '2rem', textAlign: 'center' }
      }, [
        React.createElement('h2', { key: 'title', style: { color: '#ef4444' } }, 'Tree Data Missing'),
        React.createElement('p', { key: 'desc', className: 'secondary-text' }, 'Tree data is not available. Please refresh the page.'),
        React.createElement('button', {
          key: 'btn',
          className: 'primary-button',
          onClick: () => window.location.reload()
        }, 'Reload Page')
      ]);
    }
    
    // Early validation - simplified
    if (!tree.fields || !Array.isArray(tree.fields) || tree.fields.length === 0) {
      console.error('TreeScreen: Invalid or empty tree data');
      return React.createElement('div', {
        className: 'screen',
        style: { padding: '2rem', textAlign: 'center' }
      }, [
        React.createElement('div', { key: 'text', className: 'secondary-text' }, 'No tree data available'),
        React.createElement('button', {
          key: 'btn',
          className: 'primary-button',
          onClick: () => window.location.reload()
        }, 'Reload Page')
      ]);
    }
    
    console.log('TreeScreen: Validation passed, fields count:', tree.fields.length);

    // Enhanced state management with persistence + zoom/pan + themes
    const [expandedIds, setExpandedIds] = useExpansionState();
    const [nodePositions, setNodePositions] = useState({});
    const [draggedNodeId, setDraggedNodeId] = useState(null);
    const [search, setSearch] = useState('');
    const [showNotes, setShowNotes] = useState(false);
    const [selectedNodeId, setSelectedNodeId] = useState(null);
    const [noteText, setNoteText] = useState('');
    const [viewState, setViewState] = useState({ zoom: 1, panOffset: { x: 0, y: 0 } });
    const { zoom, panOffset } = viewState;
    const [isPanning, setIsPanning] = useState(false);
    const [nodeThemes, setNodeThemes] = useState(() => {
      try {
        const stored = localStorage.getItem('cryptoExplorer.nodeThemes');
        return stored ? JSON.parse(stored) : {};
      } catch {
        return {};
      }
    });
    const [treeVersion, setTreeVersion] = useState(0);
    const [justExpanded, setJustExpanded] = useState(new Set());
    const { notes, addNote, deleteNote } = useNotes();
    const dragInfo = useRef({ startX: 0, startY: 0, initialNodeX: 0, initialNodeY: 0 });
    const panInfo = useRef({ startX: 0, startY: 0, initialPanX: 0, initialPanY: 0 });
    const containerRef = useRef(null);

    // Optimal spawn angle calculation using push vector
    const getOptimalSpawnAngle = useCallback((parentPos, allVisiblePositions) => {
      let pushX = 0;
      let pushY = 0;

      Object.values(allVisiblePositions).forEach(pos => {
        const dx = parentPos.x - pos.x;
        const dy = parentPos.y - pos.y;
        const distSq = dx * dx + dy * dy;
        
        if (distSq > 0 && distSq < 1000000) {
          const force = 1 / Math.sqrt(distSq);
          pushX += dx * force;
          pushY += dy * force;
        }
      });

      if (pushX === 0 && pushY === 0) return Math.random() * Math.PI * 2;

      const baseAngle = Math.atan2(pushY, pushX);
      const jitter = (Math.random() - 0.5) * 0.8;
      
      return baseAngle + jitter;
    }, []);

    // Enhanced TreeTile component with description, theme, and link support
    const TreeTile = memo(({ node, position, isExpanded, onMouseDown, onClick, onOpen, onRightClick, level, childrenCount, hasNotes, onThemeChange, onCopyLink, nodeTheme }) => {
      if (!node || !position) return null;
      
      // Get short description (first 2 lines or 100 characters)
      const getShortDescription = (description) => {
        if (!description) return '';
        const lines = description.split('\n').filter(line => line.trim());
        if (lines.length >= 2) {
          return lines.slice(0, 2).join(' ').substring(0, 100) + '...';
        }
        return description.substring(0, 100) + (description.length > 100 ? '...' : '');
      };
      
      const shortDesc = getShortDescription(node.description);
      
      return React.createElement('div', {
        className: `tree-section-tile tree-section-tile--theme-${nodeTheme} ${isExpanded ? 'tree-section-tile--active' : ''} ${hasNotes ? 'tree-section-tile--has-notes' : ''}`,
        style: {
          position: 'absolute',
          transform: `translate3d(${position.x}px, ${position.y}px, 0)`,
          zIndex: level,
          cursor: 'grab',
          width: '240px',
          height: '120px',
          borderRadius: '8px',
          overflow: 'hidden',
          willChange: 'transform',
          display: 'flex',
          flexDirection: 'column'
        },
        onMouseDown: (e) => {
          if (e.target.closest('select, button, .theme-selector, .copy-link-btn')) {
            return;
          }
          onMouseDown && onMouseDown(e, node);
        },
        onClick: (e) => {
          if (e.target.closest('select, button, .theme-selector, .copy-link-btn, .tree-section-title')) {
            return;
          }
          onClick && onClick(node);
        },
        onDoubleClick: (e) => {
          if (e.target.closest('select, button, .theme-selector, .copy-link-btn, .tree-section-title')) {
            return;
          }
          onClick && onClick(node);
        },
        onContextMenu: (e) => onRightClick && onRightClick(e, node)
      }, [
        // Title and description
        React.createElement('div', { key: 'header', className: 'tree-section-header' }, [
          React.createElement('div', { 
            key: 'title', 
            className: 'tree-section-title',
            onClick: (e) => {
              e.stopPropagation();
              onOpen && onOpen(node);
            },
            style: { cursor: 'pointer' }
          }, node.name),
          shortDesc && React.createElement('div', { 
            key: 'description', 
            className: 'tree-section-description' 
          }, shortDesc)
        ]),
        
        // Meta information with actions
        React.createElement('div', { key: 'meta', className: 'tree-section-meta' }, [
          // Tags
          ...(node.tags || []).slice(0, 2).map(tag => 
            React.createElement('span', { key: tag, className: 'tag-pill' }, tag)
          ),
          
          // Notes indicator
          hasNotes && React.createElement('span', {
            key: 'notes-indicator',
            className: 'notes-indicator',
            title: 'Has notes'
          }, 'ðŸ“'),
          
          // Theme selector
          React.createElement('select', {
            key: 'theme-selector',
            className: 'theme-selector',
            value: nodeTheme,
            onChange: (e) => {
              e.stopPropagation();
              onThemeChange && onThemeChange(node.id, e.target.value);
            },
            onMouseDown: (e) => e.stopPropagation(),
            onFocus: (e) => e.stopPropagation(),
            onClick: (e) => e.stopPropagation(),
            title: 'Select theme for this branch'
          }, [
            React.createElement('option', { key: 'default', value: 'default' }, 'Default'),
            React.createElement('option', { key: 'blue', value: 'blue' }, 'Blue'),
            React.createElement('option', { key: 'green', value: 'green' }, 'Green'),
            React.createElement('option', { key: 'purple', value: 'purple' }, 'Purple'),
            React.createElement('option', { key: 'orange', value: 'orange' }, 'Orange')
          ]),
          
          // Copy link button - FIXED: Ensure visibility
          React.createElement('button', {
            key: 'copy-link',
            className: 'copy-link-btn',
            onClick: (e) => {
              e.stopPropagation();
              onCopyLink && onCopyLink(node.id);
            },
            style: {
              background: 'rgba(59, 130, 246, 0.2)',
              border: '1px solid rgba(59, 130, 246, 0.5)',
              color: '#60a5fa',
              padding: '0.25rem 0.5rem',
              borderRadius: '4px',
              fontSize: '0.7rem',
              cursor: 'pointer',
              marginLeft: '0.25rem'
            },
            title: 'Copy link to this block'
          }, 'ðŸ”—'),
          
          // Children count indicator
          childrenCount > 0 && React.createElement('span', {
            key: 'indicator',
            className: 'tree-expand-indicator'
          }, isExpanded ? 'âˆ’' : '+')
        ])
      ]);
    });

    const CurvedConnection = memo(({ from, to, theme }) => {
      if (!from || !to) return null;
      
      const dx = to.x - from.x;
      const dy = to.y - from.y;
      
      let fromPoint, toPoint;
      
      if (Math.abs(dx) > Math.abs(dy)) {
        fromPoint = { x: from.x + (dx > 0 ? 90 : -90), y: from.y };
        toPoint = { x: to.x + (dx > 0 ? -90 : 90), y: to.y };
      } else {
        fromPoint = { x: from.x, y: from.y + (dy > 0 ? 50 : -50) };
        toPoint = { x: to.x, y: to.y + (dy > 0 ? -50 : 50) };
      }
      
      const controlOffset = Math.min(Math.sqrt(dx * dx + dy * dy) * 0.3, 80);
      const control1X = fromPoint.x + (Math.abs(dx) > Math.abs(dy) ? (dx > 0 ? controlOffset : -controlOffset) : 0);
      const control1Y = fromPoint.y + (Math.abs(dx) <= Math.abs(dy) ? (dy > 0 ? controlOffset : -controlOffset) : 0);
      const control2X = toPoint.x + (Math.abs(dx) > Math.abs(dy) ? (dx > 0 ? -controlOffset : controlOffset) : 0);
      const control2Y = toPoint.y + (Math.abs(dx) <= Math.abs(dy) ? (dy > 0 ? -controlOffset : controlOffset) : 0);
      
      const strokeColor = { default: 'rgba(56, 189, 248, 0.6)', blue: 'rgba(59, 130, 246, 0.7)', green: 'rgba(34, 197, 94, 0.7)', purple: 'rgba(168, 85, 247, 0.7)', orange: 'rgba(251, 146, 60, 0.7)' }[theme] || 'rgba(56, 189, 248, 0.6)';
      
      return React.createElement('svg', {
        key: `connection-${from.id}-${to.id}`,
        style: { position: 'absolute', left: '0', top: '0', width: '100%', height: '100%', pointerEvents: 'none', zIndex: 1 }
      }, [
        React.createElement('path', {
          key: 'path',
          d: `M ${fromPoint.x} ${fromPoint.y} C ${control1X} ${control1Y} ${control2X} ${control2Y} ${toPoint.x} ${toPoint.y}`,
          stroke: strokeColor,
          strokeWidth: '3',
          fill: 'none',
          opacity: '0.9',
          strokeLinecap: 'round'
        })
      ]);
    });

    // FIXED: Only center on initial load, not on every nodePositions change
    const [hasInitiallyPositioned, setHasInitiallyPositioned] = useState(false);
    
    useEffect(() => {
      if (Object.keys(nodePositions).length === 0 || hasInitiallyPositioned) return;
      
      // Find the center of mass of all visible tiles (only once)
      const positions = Object.values(nodePositions);
      if (positions.length === 0) return;
      
      const centerX = positions.reduce((sum, pos) => sum + pos.x, 0) / positions.length;
      const centerY = positions.reduce((sum, pos) => sum + pos.y, 0) / positions.length;
      
      // Center the view on the concentration of tiles
      const containerRect = containerRef.current?.getBoundingClientRect();
      if (containerRect) {
        const viewportCenterX = containerRect.width / 2;
        const viewportCenterY = containerRect.height / 2;
        
        setViewState(prev => ({
          ...prev,
          panOffset: {
            x: viewportCenterX - centerX,
            y: viewportCenterY - centerY
          }
        }));
        setHasInitiallyPositioned(true);
      }
    }, [nodePositions, hasInitiallyPositioned]);

    // Center viewport on specific node
    const centerOnNode = useCallback((nodeId) => {
      const nodePos = nodePositions[nodeId];
      if (!nodePos || !containerRef.current) return;
      
      const containerRect = containerRef.current.getBoundingClientRect();
      const viewportCenterX = containerRect.width / 2;
      const viewportCenterY = containerRect.height / 2;
      
      // Calculate new pan offset to center the node
      const newPanX = viewportCenterX - (nodePos.x * zoom);
      const newPanY = viewportCenterY - (nodePos.y * zoom);
      
      // Smooth animation to center
      const startPanX = panOffset.x;
      const startPanY = panOffset.y;
      const duration = 800; // 800ms animation
      const startTime = Date.now();
      
      const animateCenter = () => {
        const elapsed = Date.now() - startTime;
        const progress = Math.min(elapsed / duration, 1);
        
        // Easing function for smooth animation
        const easeInOutCubic = (t) => t < 0.5 ? 4 * t * t * t : (t - 1) * (2 * t - 2) * (2 * t - 2) + 1;
        const easedProgress = easeInOutCubic(progress);
        
        const currentPanX = startPanX + (newPanX - startPanX) * easedProgress;
        const currentPanY = startPanY + (newPanY - startPanY) * easedProgress;
        
        setViewState(prev => ({
          ...prev,
          panOffset: { x: currentPanX, y: currentPanY }
        }));
        
        if (progress < 1) {
          requestAnimationFrame(animateCenter);
        }
      };
      
    // ENHANCED: Smart auto-expand path to node with intelligent animation and centering
    const expandToNode = useCallback((nodeId, shouldCenter = false) => {
      try {
        console.log('TreeScreen: expandToNode called with:', { nodeId, shouldCenter });
        
        if (!tree || !tree.fields || !nodeId) {
          console.warn('TreeScreen: expandToNode - Invalid parameters:', { tree: !!tree, fields: !!tree?.fields, nodeId });
          return;
        }
        
        console.log('TreeScreen: Tree fields available:', tree?.fields?.length);
        
        // Enhanced path finding with better error handling and node validation
        const findPath = (nodes, targetId, path = []) => {
          if (!Array.isArray(nodes)) return null;
          
          try {
            for (const node of nodes) {
              if (!node || !node.id) continue;
              
              const currentPath = [...path, node.id];
              if (node.id === targetId) {
                console.log('TreeScreen: Found path to node:', currentPath);
                return currentPath;
              }
              
              const children = getChildren(node);
              if (children && children.length > 0) {
                const found = findPath(children, targetId, currentPath);
                if (found) return found;
              }
            }
          } catch (error) {
            console.error('TreeScreen: Error in findPath:', error);
            return null;
          }
          return null;
        };
        
        const path = findPath(tree.fields, nodeId);
        console.log('TreeScreen: Path found:', path);
        
        if (!path) {
          console.warn('TreeScreen: Could not find path to node:', nodeId);
          // Fallback: try to center anyway if shouldCenter is true
          if (shouldCenter) {
            setTimeout(() => centerOnNode(nodeId), 200);
          }
          return;
        }
        
        if (path.length > 0) {
          // Smart expansion strategy: expand all parent nodes but not the target itself
          const expandPath = path.length > 1 ? path.slice(0, -1) : [];
          console.log('TreeScreen: Will expand path:', expandPath);
          
          if (expandPath.length > 0) {
            // Enhanced gradual expansion with intelligent timing
            let currentIndex = 0;
            const baseDelay = 200; // Base delay between expansions
            
            const expandInterval = setInterval(() => {
              try {
                if (currentIndex >= expandPath.length) {
                  clearInterval(expandInterval);
                  console.log('TreeScreen: Expansion complete, centering:', shouldCenter);
                  
                  // Enhanced centering with better timing
                  if (shouldCenter) {
                    // Wait for layout to settle, then center with smooth animation
                    setTimeout(() => {
                      try {
                        console.log('TreeScreen: Centering on target node:', nodeId);
                        centerOnNode(nodeId);
                        
                        // Optional: Highlight the target node briefly
                        const targetElement = document.querySelector(`[data-node-id="${nodeId}"]`);
                        if (targetElement) {
                          targetElement.style.transition = 'all 0.3s ease';
                          targetElement.style.transform = 'scale(1.05)';
                          targetElement.style.boxShadow = '0 8px 30px rgba(56, 189, 248, 0.4)';
                          
                          setTimeout(() => {
                            if (targetElement) {
                              targetElement.style.transform = '';
                              targetElement.style.boxShadow = '';
                            }
                          }, 1000);
                        }
                      } catch (error) {
                        console.error('TreeScreen: Error in centering/highlighting:', error);
                      }
                    }, Math.min(600, expandPath.length * 100)); // Dynamic wait time based on path length
                  }
                  return;
                }
                
                const nodeIdToExpand = expandPath[currentIndex];
                console.log('TreeScreen: Expanding node:', nodeIdToExpand, `(${currentIndex + 1}/${expandPath.length})`);
                
                // Check if node is already expanded to avoid redundant operations
                setExpandedIds(prev => {
                  try {
                    if (prev.has(nodeIdToExpand)) {
                      console.log('TreeScreen: Node already expanded:', nodeIdToExpand);
                      return prev;
                    }
                    
                    const newExpanded = new Set(prev);
                    newExpanded.add(nodeIdToExpand);
                    console.log('TreeScreen: New expanded IDs:', [...newExpanded]);
                    return newExpanded;
                  } catch (error) {
                    console.error('TreeScreen: Error in setExpandedIds:', error);
                    return prev;
                  }
                });
                
                currentIndex++;
              } catch (error) {
                console.error('TreeScreen: Error in expansion interval:', error);
                clearInterval(expandInterval);
              }
            }, baseDelay);
          } else if (shouldCenter) {
            // No expansion needed, just center
            setTimeout(() => centerOnNode(nodeId), 200);
          }
        }
      } catch (error) {
        console.error('TreeScreen: Error in expandToNode:', error);
      }
    }, [tree, setExpandedIds, centerOnNode]);

    // Theme management functions
    const setNodeTheme = useCallback((nodeId, theme) => {
      setNodeThemes(prev => {
        const newThemes = { ...prev, [nodeId]: theme };
        // Save to localStorage
        try {
          localStorage.setItem('cryptoExplorer.nodeThemes', JSON.stringify(newThemes));
        } catch {}
        return newThemes;
      });
    }, []);

    const getNodeTheme = useCallback((nodeId) => {
      return nodeThemes[nodeId] || 'default';
    }, [nodeThemes]);

    // Apply theme to node and all its descendants
    const applyThemeToHierarchy = useCallback((nodeId, theme) => {
      const applyToDescendants = (nodes, targetId, themeToApply) => {
        for (const node of nodes) {
          if (node.id === targetId) {
            setNodeTheme(node.id, themeToApply);
            // Apply to all children
            const children = getChildren(node);
            children.forEach(child => {
              applyToDescendants([child], child.id, themeToApply);
            });
            return true;
          }
          const children = getChildren(node);
          if (applyToDescendants(children, targetId, themeToApply)) {
            return true;
          }
        }
        return false;
      };
      
      applyToDescendants(tree.fields, nodeId, theme);
    }, [tree, setNodeTheme]);

    // Link copying function
    const copyNodeLink = useCallback((nodeId) => {
      const link = `${window.location.origin}${window.location.pathname}#tree-${nodeId}`;
      navigator.clipboard.writeText(link).then(() => {
        // Visual feedback could be added here
        console.log('Link copied:', link);
      }).catch(() => {
        console.error('Failed to copy link');
      });
    }, []);



    const findNearbyPosition = useCallback((parentId, childIndex, allPositions) => {
      const parentPos = nodePositions[parentId];
      if (!parentPos) return { x: 100, y: 100 };
      
      const tileSize = 180; // Increased collision radius with border
      const minDistance = 200;
      const maxAttempts = 50;
      
      for (let attempt = 0; attempt < maxAttempts; attempt++) {
        const angle = Math.random() * Math.PI * 2;
        const distance = minDistance + (Math.random() * 100);
        const testX = parentPos.x + Math.cos(angle) * distance;
        const testY = parentPos.y + Math.sin(angle) * distance;
        
        const hasCollision = Object.values(allPositions).some(pos => {
          const dx = pos.x - testX;
          const dy = pos.y - testY;
          return Math.sqrt(dx * dx + dy * dy) < tileSize;
        });
        
        if (!hasCollision) {
          return { x: testX, y: testY };
        }
      }
      
      // Fallback: spiral outward
      const fallbackAngle = childIndex * (Math.PI * 2 / 8);
      const fallbackDistance = minDistance + (childIndex * 50);
      return {
        x: parentPos.x + Math.cos(fallbackAngle) * fallbackDistance,
        y: parentPos.y + Math.sin(fallbackAngle) * fallbackDistance
      };
    }, [nodePositions]);

    // Recursive collapse function
    const collapseDescendants = useCallback((nodeId, expanded) => {
      const toCollapse = new Set();
      
      const findDescendants = (nodes) => {
        nodes.forEach(node => {
          if (expanded.has(node.id)) {
            toCollapse.add(node.id);
            const children = getChildren(node);
            if (children.length > 0) {
              findDescendants(children);
            }
          }
        });
      };
      
      const findNodeInTree = (nodes, targetId) => {
        for (const node of nodes) {
          if (node.id === targetId) return node;
          const children = getChildren(node);
          const found = findNodeInTree(children, targetId);
          if (found) return found;
        }
        return null;
      };
      
      const targetNode = findNodeInTree(tree.fields, nodeId);
      if (targetNode) {
        const children = getChildren(targetNode);
        findDescendants(children);
      }
      
      return toCollapse;
    }, [tree]);

    // FIXED: Layout calculation with stable memoized position calculator
    const calculatePositionsRef = useRef(null);
    
    useEffect(() => {
      if (!tree || !tree.fields) return;
      
      // Debounce to prevent rapid recalculations
      if (calculatePositionsRef.current) {
        clearTimeout(calculatePositionsRef.current);
      }
      
      calculatePositionsRef.current = setTimeout(() => {
        setNodePositions(currentPositions => {
          const positions = { ...currentPositions };
          const tileSize = 200;
          const centerX = 2500;
          const centerY = 2500;
          
          // Pre-calculate all positions in single pass
          const calculateLayout = (nodes, level = 0, parentPos = null, parentId = null) => {
            if (!nodes || !Array.isArray(nodes)) return;
            
            nodes.forEach((node, index) => {
              if (!node || !node.id) return;
              
              // Never recalculate existing positions
              if (positions[node.id]?.x !== undefined) {
                if (expandedIds.has(node.id)) {
                  const children = getChildren(node);
                  calculateLayout(children, level + 1, positions[node.id], node.id);
                }
                return;
              }
              
              // Calculate new position ONCE
              let newPos;
              if (parentPos && level > 0) {
                // Child node positioning
                const baseAngle = (index / Math.max(nodes.length, 1)) * Math.PI * 2;
                const distance = 250 + (level * 80);
                newPos = {
                  x: parentPos.x + Math.cos(baseAngle) * distance,
                  y: parentPos.y + Math.sin(baseAngle) * distance
                };
              } else {
                // Root node positioning
                const angle = (index / Math.max(nodes.length, 1)) * Math.PI * 2;
                const radius = 300 + (nodes.length * 30);
                newPos = {
                  x: centerX + Math.cos(angle) * radius,
                  y: centerY + Math.sin(angle) * radius
                };
              }
              
              positions[node.id] = newPos;
              
              if (expandedIds.has(node.id)) {
                const children = getChildren(node);
                calculateLayout(children, level + 1, newPos, node.id);
              }
            });
          };
          
          calculateLayout(tree.fields);
          return positions;
        });
      }, 50); // 50ms debounce
      
      return () => clearTimeout(calculatePositionsRef.current);
    }, [expandedIds, tree, treeVersion]);

    // FIXED: Stable zoom with atomic updates
    const handleWheel = useCallback((e) => {
      e.preventDefault();
      
      const rect = containerRef.current?.getBoundingClientRect();
      if (!rect) return;
      
      setViewState(prev => {
        const mouseX = e.clientX - rect.left;
        const mouseY = e.clientY - rect.top;
        const worldX = (mouseX - prev.panOffset.x) / prev.zoom;
        const worldY = (mouseY - prev.panOffset.y) / prev.zoom;
        
        const factor = e.deltaY > 0 ? 0.9 : 1.1;
        const newZoom = Math.max(0.1, Math.min(3, prev.zoom * factor));
        
        return {
          zoom: newZoom,
          panOffset: {
            x: mouseX - worldX * newZoom,
            y: mouseY - worldY * newZoom
          }
        };
      });
    }, []);

    const handlePanStart = useCallback((e) => {
      if (draggedNodeId || e.target.closest('.tree-section-tile')) return;
      setIsPanning(true);
      panInfo.current = {
        startX: e.clientX,
        startY: e.clientY,
        initialPanX: panOffset.x,
        initialPanY: panOffset.y
      };
    }, [draggedNodeId, panOffset]);

    // FIXED: Synchronous drag with immediate position updates
    const handleMouseMove = useCallback((e) => {
      if (draggedNodeId && dragInfo.current) {
        const rect = containerRef.current?.getBoundingClientRect();
        if (!rect) return;
        
        // Calculate delta in screen space
        const deltaScreenX = e.clientX - dragInfo.current.startX;
        const deltaScreenY = e.clientY - dragInfo.current.startY;
        
        // Convert to world space delta
        const deltaWorldX = deltaScreenX / zoom;
        const deltaWorldY = deltaScreenY / zoom;
        
        // Update position IMMEDIATELY (no RAF throttle)
        setNodePositions(prev => ({
          ...prev,
          [draggedNodeId]: {
            x: dragInfo.current.initialNodeX + deltaWorldX,
            y: dragInfo.current.initialNodeY + deltaWorldY
          }
        }));
        
      } else if (isPanning && panInfo.current) {
        const deltaX = e.clientX - panInfo.current.startX;
        const deltaY = e.clientY - panInfo.current.startY;
        
        setViewState(prev => ({
          ...prev,
          panOffset: {
            x: panInfo.current.initialPanX + deltaX,
            y: panInfo.current.initialPanY + deltaY
          }
        }));
      }
    }, [draggedNodeId, isPanning, zoom]);

    // FIXED: Mouse down with proper coordinate capture
    const handleMouseDown = useCallback((e, node) => {
      if (!node || !node.id) return;
      e.stopPropagation();
      
      const pos = nodePositions[node.id];
      if (!pos) return;
      
      setDraggedNodeId(node.id);
      dragInfo.current = {
        startX: e.clientX,
        startY: e.clientY,
        initialNodeX: pos.x,
        initialNodeY: pos.y
      };
    }, [nodePositions]);

    const handleMouseUp = useCallback(() => {
      // No need to commit offset - positions already updated during drag
      setDraggedNodeId(null);
      setIsPanning(false);
    }, []);

    // Expandable / collapsible nodes with hierarchical folding
    const handleTileClick = useCallback((node) => {
      try {
        if (!node || !node.id) return;
        
        const newExpanded = new Set(expandedIds);
        const newJustExpanded = new Set();
        
        if (newExpanded.has(node.id)) {
          // Folding: collapse this node and all descendants
          newExpanded.delete(node.id);
          const descendantsToCollapse = collapseDescendants(node.id, newExpanded);
          descendantsToCollapse.forEach(id => newExpanded.delete(id));
        } else {
          // Expanding: add this node and mark as just expanded
          newExpanded.add(node.id);
          newJustExpanded.add(node.id);
        }
        
        setExpandedIds(newExpanded);
        setJustExpanded(newJustExpanded);
      } catch (error) {
        console.error('handleTileClick error:', error);
      }
    }, [expandedIds, setExpandedIds, collapseDescendants]);

    // Notes functionality
    const handleAddNote = useCallback(() => {
      if (noteText.trim() && selectedNodeId) {
        addNote(selectedNodeId, noteText.trim());
        setNoteText('');
        setShowNotes(false);
      }
    }, [noteText, selectedNodeId, addNote]);

    const handleNodeRightClick = useCallback((e, node) => {
      e.preventDefault();
      setSelectedNodeId(node.id);
      setShowNotes(true);
    }, []);

    // Flatten tree for search with correct path hierarchy
    const flatNodes = useMemo(() => {
      if (!tree || !tree.fields) return [];
      
      const flatten = (nodes, path = []) => {
        return nodes.reduce((acc, node) => {
          const currentPath = [...path, node.name];
          const fullPath = currentPath.join(' / ');
          
          const nodeWithPaths = {
            ...node,
            path: currentPath,
            fullPath: currentPath,
            pathString: fullPath // For easy copying
          };
          
          const children = getChildren(node);
          const childResults = children.length > 0 ? flatten(children, currentPath) : [];
          
          return [...acc, nodeWithPaths, ...childResults];
        }, []);
      };
      
      return flatten(tree.fields);
    }, [tree]);

    const filteredResults = useMemo(() => {
      const q = search.trim().toLowerCase();
      if (!q) return [];
      
      // Enhanced path search - match copied paths
      if (q.includes(' / ')) {
        const pathParts = q.split(' / ').map(p => p.trim());
        return flatNodes.filter(n => {
          if (!n.fullPath) return false;
          return pathParts.every((part, i) => 
            i < n.fullPath.length && n.fullPath[i].toLowerCase().includes(part)
          );
        });
      }
      
      // Regular search with path matching
      return flatNodes.filter(n => {
        const pathString = n.fullPath ? n.fullPath.join(' / ') : n.name;
        return n.name.toLowerCase().includes(q) ||
               n.description?.toLowerCase().includes(q) ||
               pathString.toLowerCase().includes(q) ||
               (n.tags || []).some(t => t.toLowerCase().includes(q));
      });
    }, [flatNodes, search]);

    // FIXED: Stable callback refs to prevent render loops
    const handleMouseDownRef = useRef(handleMouseDown);
    const handleTileClickRef = useRef(handleTileClick);
    const handleNodeRightClickRef = useRef(handleNodeRightClick);
    const onOpenArticleRef = useRef(onOpenArticle);
    const applyThemeToHierarchyRef = useRef(applyThemeToHierarchy);
    const copyNodeLinkRef = useRef(copyNodeLink);
    
    useEffect(() => {
      handleMouseDownRef.current = handleMouseDown;
      handleTileClickRef.current = handleTileClick;
      handleNodeRightClickRef.current = handleNodeRightClick;
      onOpenArticleRef.current = onOpenArticle;
      applyThemeToHierarchyRef.current = applyThemeToHierarchy;
      copyNodeLinkRef.current = copyNodeLink;
    });

    const renderRecursive = useCallback((node, level = 0) => {
      try {
        if (!node || !node.id) {
          console.log('TreeScreen: Invalid node in renderRecursive:', node);
          return null;
        }
        
        // FIXED: Single source of truth - nodePositions only
        const pos = nodePositions[node.id] || { x: 100 + level * 200, y: 100 + level * 120 };
        
        const nodeNotes = notes.filter(n => n.sectionId === node.id);
        const children = getChildren(node);
        const isExpanded = expandedIds.has(node.id);

        return React.createElement(React.Fragment, { key: node.id }, [
          React.createElement(TreeTile, {
            key: `tile-${node.id}`,
            node,
            position: pos, // Direct position, no offset calculation
            level,
            isExpanded,
            childrenCount: children.length,
            hasNotes: nodeNotes.length > 0,
            onMouseDown: handleMouseDownRef.current,
            onOpen: onOpenArticleRef.current,
            onClick: handleTileClickRef.current,
            onRightClick: handleNodeRightClickRef.current,
            onThemeChange: applyThemeToHierarchyRef.current,
            onCopyLink: copyNodeLinkRef.current,
            nodeTheme: getNodeTheme(node.id)
          }),
          
          ...(isExpanded ? children.map(child => renderRecursive(child, level + 1)).filter(Boolean) : [])
        ]);
      } catch (error) {
        console.error('renderRecursive error:', error);
        return null;
      }
    }, [nodePositions, expandedIds, notes, getNodeTheme]);

    // Listen for tree updates and cleanup
    useEffect(() => {
      const handleTreeUpdate = (event) => {
        console.log('TreeScreen: Tree update event received:', event.detail);
        setTreeVersion(prev => prev + 1);
        setNodePositions({}); // FIXED: Clear positions for new nodes
        setExpandedIds(new Set()); // FIXED: Reset expansion state
      };
      
      const handleArticleAdded = (event) => {
        const { articleId } = event.detail;
        console.log('TreeScreen: New article added:', articleId);
        
        // FIXED: Force complete re-render
        setTreeVersion(prev => prev + 1);
        setNodePositions({});
        
        setTimeout(() => {
          if (articleId) {
            expandToNode(articleId, true);
          }
        }, 500);
      };
      
      const handleBookmarkNavigation = (event) => {
        const { nodeId } = event.detail;
        console.log('TreeScreen: Bookmark navigation to:', nodeId);
        if (nodeId) {
          expandToNode(nodeId, true);
        }
      };
      
      const handleApiTreeUpdate = async () => {
        console.log('TreeScreen: API tree update detected, refreshing...');
        setTreeVersion(prev => prev + 1);
        setNodePositions({});
      };
      
      // Cleanup function to prevent black panels
      const cleanup = () => {
        // Clear any lingering styles or elements
        const treeElements = document.querySelectorAll('.tree-space, .tree-section-tile');
        treeElements.forEach(el => {
          if (el.style) {
            el.style.background = '';
            el.style.position = '';
          }
        });
      };
      
      window.addEventListener('treeUpdated', handleTreeUpdate);
      window.addEventListener('articleAdded', handleArticleAdded);
      window.addEventListener('navigateToBookmark', handleBookmarkNavigation);
      window.addEventListener('apiTreeUpdate', handleApiTreeUpdate);
      window.addEventListener('beforeunload', cleanup);
      
      return () => {
        window.removeEventListener('treeUpdated', handleTreeUpdate);
        window.removeEventListener('articleAdded', handleArticleAdded);
        window.removeEventListener('navigateToBookmark', handleBookmarkNavigation);
        window.removeEventListener('apiTreeUpdate', handleApiTreeUpdate);
        window.removeEventListener('beforeunload', cleanup);
        cleanup(); // Run cleanup on unmount
      };
    }, [expandToNode]);

    // Expose expandToNode globally for debugging
    useEffect(() => {
      window.TreeScreenExpandToNode = expandToNode;
      return () => {
        window.TreeScreenExpandToNode = null;
      };
    }, [expandToNode]);

    return React.createElement('div', {
      className: 'screen',
      style: { 
        padding: 0, 
        margin: 0, 
        height: '100vh', 
        overflow: 'hidden',
        position: 'relative',
        background: '#0f172a' // FIX 10: Solid background to prevent black screen
      }
    }, [
      // Search bar
      React.createElement('div', {
        key: 'search-bar',
        className: 'search-bar',
        style: { position: 'absolute', top: '10px', left: '10px', right: '10px', zIndex: 200 }
      }, [
        React.createElement('input', {
          key: 'search-input',
          className: 'search-input',
          placeholder: 'Search inside the CryptoMap tree...',
          value: search,
          onChange: e => setSearch(e.target.value)
        })
      ]),

      // Notes modal
      showNotes && React.createElement('div', {
        key: 'notes-modal',
        className: 'notes-modal',
        style: {
          position: 'fixed',
          top: 0,
          left: 0,
          right: 0,
          bottom: 0,
          background: 'rgba(0,0,0,0.5)',
          zIndex: 1000,
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center'
        },
        onClick: () => setShowNotes(false)
      }, [
        React.createElement('div', {
          key: 'modal-content',
          style: {
            background: '#1e293b',
            padding: '2rem',
            borderRadius: '8px',
            maxWidth: '500px',
            width: '90%'
          },
          onClick: e => e.stopPropagation()
        }, [
          React.createElement('h3', { key: 'title' }, 'Add Note'),
          React.createElement('textarea', {
            key: 'textarea',
            value: noteText,
            onChange: e => setNoteText(e.target.value),
            placeholder: 'Enter your note...',
            style: {
              width: '100%',
              height: '100px',
              margin: '1rem 0',
              padding: '0.5rem',
              background: '#374151',
              border: '1px solid #4b5563',
              borderRadius: '4px',
              color: '#f7f9ff'
            }
          }),
          React.createElement('div', {
            key: 'buttons',
            style: { display: 'flex', gap: '1rem' }
          }, [
            React.createElement('button', {
              key: 'save',
              onClick: handleAddNote,
              className: 'primary-button'
            }, 'Save Note'),
            React.createElement('button', {
              key: 'cancel',
              onClick: () => setShowNotes(false),
              className: 'secondary-button'
            }, 'Cancel')
          ]),
          // Show existing notes
          selectedNodeId && notes.filter(n => n.sectionId === selectedNodeId).length > 0 && React.createElement('div', {
            key: 'existing-notes',
            style: { marginTop: '1rem' }
          }, [
            React.createElement('h4', { key: 'existing-title' }, 'Existing Notes:'),
            ...notes.filter(n => n.sectionId === selectedNodeId).map(note =>
              React.createElement('div', {
                key: note.id,
                style: {
                  background: '#374151',
                  padding: '0.5rem',
                  margin: '0.5rem 0',
                  borderRadius: '4px',
                  display: 'flex',
                  justifyContent: 'space-between',
                  alignItems: 'center'
                }
              }, [
                React.createElement('span', { key: 'text' }, note.text),
                React.createElement('button', {
                  key: 'delete',
                  onClick: () => deleteNote(note.id),
                  style: {
                    background: '#ef4444',
                    border: 'none',
                    padding: '0.25rem 0.5rem',
                    borderRadius: '4px',
                    color: 'white',
                    cursor: 'pointer'
                  }
                }, 'Delete')
              ])
            )
          ])
        ])
      ]),

      // Tree space container with single clean map
      !search ? React.createElement('div', {
        key: 'tree-space-container',
        ref: containerRef,
        style: {
          position: 'absolute',
          top: '60px',
          left: '0',
          right: '0',
          bottom: '0',
          overflow: 'hidden',
          background: 'radial-gradient(circle at center, rgba(15, 23, 42, 0.8), rgba(5, 8, 20, 0.9))'
        },
        onMouseDown: handlePanStart,
        onMouseMove: handleMouseMove,
        onMouseUp: handleMouseUp,
        onMouseLeave: handleMouseUp,
        onWheel: handleWheel
      }, [
        React.createElement('div', {
          key: 'tree-world',
          style: {
            transform: `translate(${panOffset.x}px, ${panOffset.y}px) scale(${zoom})`,
            transformOrigin: '0 0',
            position: 'absolute',
            width: '5000px',
            height: '5000px'
          }
        }, [
          // FIXED: Single SVG layer with stable connections
          React.createElement('svg', {
            key: 'connections-layer',
            style: {
              position: 'absolute',
              top: 0,
              left: 0,
              width: '100%',
              height: '100%',
              pointerEvents: 'none',
              zIndex: 1
            }
          }, (() => {
            const connections = [];
            const collectConnections = (nodes) => {
              nodes.forEach(node => {
                if (expandedIds.has(node.id)) {
                  const children = getChildren(node);
                  const nodePos = nodePositions[node.id];
                  
                  if (nodePos) {
                    children.forEach(child => {
                      const childPos = nodePositions[child.id];
                      
                      if (childPos) {
                        connections.push(React.createElement(CurvedConnection, {
                          key: `connection-${node.id}-${child.id}`,
                          from: nodePos, // Direct position, no offset
                          to: childPos, // Direct position, no offset
                          theme: getNodeTheme(node.id)
                        }));
                      }
                    });
                  }
                  collectConnections(children);
                }
              });
            };
            collectConnections(tree.fields);
            return connections;
          })()),
          
          // Single tiles layer
          React.createElement('div', {
            key: 'tiles-layer',
            style: {
              position: 'absolute',
              width: '100%',
              height: '100%'
            }
          }, tree.fields.map(field => renderRecursive(field)).filter(Boolean))
        ])
      ]) : React.createElement('div', {
        key: 'search-results',
        className: 'search-results',
        style: {
          position: 'absolute',
          top: '60px',
          left: '10px',
          right: '10px',
          maxHeight: 'calc(100vh - 80px)',
          overflow: 'auto',
          background: 'rgba(15, 23, 42, 0.95)',
          borderRadius: '8px',
          border: '1px solid rgba(148, 163, 184, 0.3)',
          zIndex: 300,
          padding: '1rem'
        }
      }, [
        filteredResults.length === 0 ? 
          React.createElement('div', { 
            key: 'no-results',
            className: 'secondary-text' 
          }, 'No matches found.') :
          React.createElement('div', { key: 'results' }, 
            filteredResults.map(n => 
              React.createElement('div', {
                key: n.id,
                className: 'search-result-item'
              }, [
                React.createElement('div', {
                  key: 'content',
                  onClick: () => {
                    expandToNode(n.id, true); // Auto-center when clicking search results
                    setSearch(''); // Clear search after selection
                  }
                }, [
                  React.createElement('div', {
                    key: 'name',
                    className: 'search-result-name'
                  }, n.name),
                  React.createElement('div', {
                    key: 'path-container',
                    className: 'search-result-path-container'
                  }, [
                    React.createElement('div', {
                      key: 'path',
                      className: 'search-result-path'
                    }, n.path ? n.path.join(' / ') : ''),
                    React.createElement('button', {
                      key: 'copy-path',
                      className: 'copy-path-btn',
                      onClick: (e) => {
                        e.stopPropagation();
                        const pathToCopy = n.pathString || (n.path ? n.path.join(' / ') : n.name);
                        navigator.clipboard.writeText(pathToCopy).then(() => {
                          // Visual feedback
                          const btn = e.target;
                          const originalText = btn.textContent;
                          btn.textContent = 'Copied!';
                          btn.style.background = '#10b981';
                          setTimeout(() => {
                            btn.textContent = originalText;
                            btn.style.background = '';
                          }, 1500);
                        }).catch(() => {
                          alert('Failed to copy path');
                        });
                      },
                      title: 'Copy path to clipboard'
                    }, 'ðŸ“‹')
                  ])
                ]),
                React.createElement('button', {
                  key: 'bookmark',
                  className: `bookmark-toggle ${bookmarksApi?.isBookmarked(n.id) ? 'bookmark-toggle--active' : ''}`,
                  onClick: e => { e.stopPropagation(); bookmarksApi?.toggleBookmark(n); }
                }, bookmarksApi?.isBookmarked(n.id) ? 'Bookmarked' : 'Bookmark')
              ])
            )
          )
      ]),

      // Zoom controls
      React.createElement('div', {
        key: 'zoom-controls',
        style: {
          position: 'absolute',
          bottom: '20px',
          right: '20px',
          zIndex: 200,
          display: 'flex',
          flexDirection: 'column',
          gap: '0.5rem'
        }
      }, [
        React.createElement('button', {
          key: 'zoom-in',
          onClick: () => setViewState(prev => ({ ...prev, zoom: Math.min(3, prev.zoom * 1.2) })),
          style: {
            padding: '0.5rem',
            background: '#374151',
            border: '1px solid #4b5563',
            borderRadius: '4px',
            color: '#f7f9ff',
            cursor: 'pointer'
          }
        }, '+'),
        React.createElement('button', {
          key: 'zoom-out',
          onClick: () => setViewState(prev => ({ ...prev, zoom: Math.max(0.1, prev.zoom * 0.8) })),
          style: {
            padding: '0.5rem',
            background: '#374151',
            border: '1px solid #4b5563',
            borderRadius: '4px',
            color: '#f7f9ff',
            cursor: 'pointer'
          }
        }, 'âˆ’'),
        React.createElement('button', {
          key: 'zoom-reset',
          onClick: () => {
            setViewState(prev => ({ ...prev, zoom: 1 }));
            // Only reset to center if we have positions and haven't positioned yet
            if (!hasInitiallyPositioned) {
              const positions = Object.values(nodePositions);
              if (positions.length > 0) {
                const centerX = positions.reduce((sum, pos) => sum + pos.x, 0) / positions.length;
                const centerY = positions.reduce((sum, pos) => sum + pos.y, 0) / positions.length;
                const containerRect = containerRef.current?.getBoundingClientRect();
                if (containerRect) {
                  setViewState(prev => ({
                    ...prev,
                    panOffset: {
                      x: containerRect.width / 2 - centerX,
                      y: containerRect.height / 2 - centerY
                    }
                  }));
                }
              }
            }
          },
          style: {
            padding: '0.5rem',
            background: '#374151',
            border: '1px solid #4b5563',
            borderRadius: '4px',
            color: '#f7f9ff',
            cursor: 'pointer',
            fontSize: '0.8rem'
          }
        }, 'âŒ‚')
      ])
    ]);
  }

  // Wrapped TreeScreen with Error Boundary
  function SafeTreeScreen(props) {
    return React.createElement(TreeErrorBoundary, null,
      React.createElement(TreeScreen, props)
    );
  }

  // Make expandToNode globally accessible for debugging
  window.TreeScreenExpandToNode = null;

  window.TreeScreen = SafeTreeScreen;
  console.log('âœ… TreeScreen registered successfully:', typeof window.TreeScreen);
}

} else {
  console.error('❌ TreeScreen.js: React not available');
}

console.log('TreeScreen.js: File execution complete. window.TreeScreen =', typeof window.TreeScreen);
