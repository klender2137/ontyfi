.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache/

# Test files and outputs
test-results/
coverage/

# Local configuration files
config.local.js
config.local.json
local.config.js
local.config.json

# Database files
*.db
*.sqlite
*.sqlite3

# Private keys and certificates
*.p12
*.pfx
*.crt
*.key
*.pem

# Backup files
*.backup
*.bak

# Lock files (keep package-lock.json but exclude others)
yarn.lock
pnpm-lock.yaml

# Exclude all JSON files except package.json and package-lock.json
*.json
!package.json
!package-lock.json
!public/*.json
!data/*.json
!data/branches/*.json

# Exclude JavaScript source maps
*.js.map
*.ts.map

# Exclude TypeScript cache
*.tsbuildinfo

# Exclude Next.js build files (if using Next.js)
.next/

# Exclude Expo files (if using Expo)
.expo/

# Exclude webpack stats
webpack-stats.json
